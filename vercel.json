{
  "version": 2,
  "builds": [
    {
      "src": "portfolio-frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "portfolio-backend/api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api(.*)", "dest": "/portfolio-backend/api/index.js" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/portfolio-frontend/dist/index.html" }
  ]
}
